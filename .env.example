# Необязательно: без .env используются те же URL и bot_chats.db в корне репозитория.
OCR_REMOTE_URL=http://localhost:8081/ocr/extract
OLLAMA_BASE_URL=http://localhost:11434

TELEGRAM_BOT_TOKEN=
# По умолчанию БД: <корень_репо>/bot_chats.db (можно переопределить)
# SQLITE_PATH=bot_chats.db

# OCR: auto | pymupdf | tesseract | paddle
# OCR_ENGINE=auto

# Роутер: при низком margin между классами — уточнение через Qwen-json
# ROUTER_LLM_DISAMBIGUATE=false
# ROUTER_AMBIGUOUS_MARGIN=0.15
# ROUTER_LLM_MIN_CONFIDENCE=0.55
